  "keyFeatures": [
    "JWT-based authentication with OAuth support",
    "Bookmark management with tags and collections",
    "Real-time collaboration with WebSocket support",
    "File storage and management with AWS S3",
    "RSS feed aggregation and management",
    "Full-text search capabilities",
    "Background job processing with NATS",
    "Rate limiting and security middleware",
    "Stripe payment integration",
    "QR code authentication"
  ],
  "publicApiSurface": [
    "POST /auth/login - User login",
    "POST /auth/signup - User registration",
    "POST /auth/token/refresh - Refresh access token",
    "GET /bookmarks - List bookmarks",
    "POST /bookmarks - Create bookmark",
    "GET /bookmarks/:id - Get bookmark details",
    "PATCH /bookmarks/:id - Update bookmark",
    "DELETE /bookmarks/:id - Delete bookmark",
    "GET /collections - List collections",
    "POST /collections - Create collection",
    "GET /collections/:id - Get collection details",
    "POST /collections/:id/send-invite - Invite user to collection",
    "GET /user - Get current user",
    "PATCH /user - Update user profile",
    "GET /search - Search bookmarks",
    "POST /parser - Parse URL metadata",
    "GET /rss-feeds - List RSS feeds",
    "POST /rss-feeds - Subscribe to RSS feed",
    "GET /oauth/authorize - OAuth authorization endpoint",
    "POST /oauth/authorize/decision - OAuth decision endpoint"
  ]
